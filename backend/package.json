{
  "name": "kisanmitra-backend",
  "version": "2.0.0",
  "description": "KisanMitra Smart Crop Advisory — Node.js v23.11.1 Backend",
  "main": "server.js",
  "engines": {
    "node": ">=23.11.1"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "ml:train": "cd ../ML && npm run train",
    "ml:serve": "cd ../ML && npm run serve",
    "ml:test": "cd ../ML && npm run test",
    "ml:status": "cd ../ML && npm run status",
    "start:full": "node -e \"require('child_process').spawn('python3',['ML/service/ml_server.py'],{cwd:'../',stdio:'ignore',detached:true}).unref()\" && node server.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^2.4.3",
    "brain.js": "1.6.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "groq-sdk": "^1.1.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
